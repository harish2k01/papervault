# PaperVault local development configuration

PAPERVAULT_ENV=development
PAPERVAULT_LOG_LEVEL=INFO
PAPERVAULT_API_CORS_ORIGINS=http://localhost:5173
PAPERVAULT_MAX_UPLOAD_SIZE_BYTES=104857600
PAPERVAULT_AI_ENABLED=true
PAPERVAULT_AI_PROVIDER=local
PAPERVAULT_ANSWER_PROVIDER=local
PAPERVAULT_EMBEDDING_PROVIDER=local
PAPERVAULT_EMBEDDING_DIMENSIONS=64
PAPERVAULT_AI_CLASSIFICATION_THRESHOLD=0.55
PAPERVAULT_MODEL_PROVIDER_TIMEOUT_SECONDS=60
PAPERVAULT_OLLAMA_BASE_URL=http://host.docker.internal:11434
PAPERVAULT_OLLAMA_CHAT_MODEL=llama3.2
PAPERVAULT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
PAPERVAULT_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
PAPERVAULT_OPENAI_COMPATIBLE_API_KEY=
PAPERVAULT_OPENAI_COMPATIBLE_CHAT_MODEL=gpt-4.1-mini
PAPERVAULT_OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-3-small
PAPERVAULT_OCR_PROVIDER=tesseract
PAPERVAULT_OCR_LANGUAGES=eng
PAPERVAULT_OCR_TIMEOUT_SECONDS=120
PAPERVAULT_OCR_PDF_DPI=200
PAPERVAULT_OCR_MAX_PDF_PAGES=50
PAPERVAULT_TESSERACT_CMD=tesseract
PAPERVAULT_PDFTOPPM_CMD=pdftoppm
PAPERVAULT_TESSERACT_PSM=6

POSTGRES_USER=papervault
POSTGRES_PASSWORD=papervault
POSTGRES_DB=papervault
DATABASE_URL=postgresql+asyncpg://papervault:papervault@postgres:5432/papervault

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=papervault
S3_SECRET_ACCESS_KEY=papervault-secret
S3_BUCKET_DOCUMENTS=documents
S3_REGION=us-east-1

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
PAPERVAULT_SEARCH_INDEX_ENABLED=true
PAPERVAULT_SEARCH_QUERY_BACKEND=opensearch
PAPERVAULT_SEARCH_QUERY_FALLBACK_ENABLED=true
OPENSEARCH_DOCUMENTS_INDEX=papervault-documents-v1
OPENSEARCH_TIMEOUT_SECONDS=5

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
OIDC_STATE_TTL_SECONDS=600
OIDC_HTTP_TIMEOUT_SECONDS=5
JWT_SIGNING_KEY=change-me-in-production
JWT_ISSUER=papervault
JWT_AUDIENCE=papervault-web
JWT_ACCESS_TOKEN_MINUTES=60
PAPERVAULT_WEB_APP_URL=http://localhost:5173
PAPERVAULT_LOCAL_AUTH_ENABLED=true
PAPERVAULT_LOCAL_REGISTRATION_ENABLED=true
PAPERVAULT_AUTH_ALLOW_DEV_HEADERS=true
PAPERVAULT_PASSWORD_HASH_ITERATIONS=600000

OTEL_SERVICE_NAME=papervault-api
OTEL_EXPORTER_OTLP_ENDPOINT=

VITE_API_BASE_URL=http://localhost:8000
