# PaperVault local development configuration

PAPERVAULT_ENV=development
PAPERVAULT_LOG_LEVEL=INFO
PAPERVAULT_API_CORS_ORIGINS=http://localhost:5173
PAPERVAULT_MAX_UPLOAD_SIZE_BYTES=104857600
PAPERVAULT_AI_ENABLED=true
PAPERVAULT_AI_PROVIDER=local
PAPERVAULT_EMBEDDING_PROVIDER=local
PAPERVAULT_EMBEDDING_DIMENSIONS=64
PAPERVAULT_AI_CLASSIFICATION_THRESHOLD=0.55

POSTGRES_USER=papervault
POSTGRES_PASSWORD=papervault
POSTGRES_DB=papervault
DATABASE_URL=postgresql+asyncpg://papervault:papervault@postgres:5432/papervault

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=papervault
S3_SECRET_ACCESS_KEY=papervault-secret
S3_BUCKET_DOCUMENTS=documents
S3_REGION=us-east-1

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_SIGNING_KEY=change-me-in-production
JWT_ISSUER=papervault
JWT_AUDIENCE=papervault-web
JWT_ACCESS_TOKEN_MINUTES=60
PAPERVAULT_LOCAL_AUTH_ENABLED=true
PAPERVAULT_LOCAL_REGISTRATION_ENABLED=true
PAPERVAULT_AUTH_ALLOW_DEV_HEADERS=true
PAPERVAULT_PASSWORD_HASH_ITERATIONS=600000

OTEL_SERVICE_NAME=papervault-api
OTEL_EXPORTER_OTLP_ENDPOINT=

VITE_API_BASE_URL=http://localhost:8000
